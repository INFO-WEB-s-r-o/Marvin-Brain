{
  "name": "marvin-brain",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev:api": "bun run --watch src/api/index.ts",
    "dev:mcp": "bun run --watch src/mcp/index.ts",
    "dev:worker": "bun run --watch src/worker/index.ts",
    "build": "bun build src/api/index.ts src/mcp/index.ts src/worker/index.ts --outdir=dist --target=bun",
    "test": "bun test",
    "test:integration": "bun test test/integration",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:setup-vectors": "bun run src/db/setup-vectors.ts",
    "seed": "bun run scripts/seed-thoughts.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.0",
    "node-cron": "^3.0.3",
    "openai": "^4.70.0",
    "postgres": "^3.4.5",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testcontainers/postgresql": "^10.13.0",
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/bun": "^1.1.13",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
