# Required
BRAIN_API_KEY=replace-me-with-a-32-char-random-secret
DATABASE_URL=postgresql://admin@postgres:5432/brain
OPENAI_API_KEY=sk-...

# Required at runtime, defaulted in docker-compose
LIGHTRAG_URL=http://lightrag:8000

# Optional tunables (defaults shown)
EMBEDDING_MODEL=text-embedding-3-small
CONSOLIDATION_MODEL=gpt-4o-mini
SIMILARITY_THRESHOLD=0.92
CLUSTER_SIM_THRESHOLD=0.85
CONSOLIDATION_WEIGHT_FLOOR=2
MIN_CLUSTER_SIZE=3
MIN_CLUSTER_WEIGHT=5
CONFIDENCE_FLOOR=0.7
PRUNE_AFTER_DAYS=14
RECENCY_HALF_LIFE_DAYS=30
LOG_LEVEL=info

# Server ports (rarely change)
API_PORT=8787
MCP_PORT=3100
